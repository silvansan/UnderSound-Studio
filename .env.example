# ablaut — environment template
#
# Copy to .env for local Docker Compose, or set these in Portainer:
# Stacks → ablaut-studio → Editor → Environment variables
# (when using PORTAINER_STACK_COPY_PASTE.yml)
#
# ═══ Safe redeploy (production / Portainer) ═══
#   PAYLOAD_DB_PUSH=false
#   PAYLOAD_RUN_MIGRATIONS=true
#   PAYLOAD_WAIT_FOR_DB=true
#
# Keep volumes ablaut_db and ablaut_uploads — do NOT delete on redeploy.
# ablaut_hls_segments is optional (HLS fallback); safe to add on upgrade.
#
# After redeploy, verify: GET /api/health?deep=1 → ok:true, dbReady:true

# --- Core (required) ---
# openssl rand -hex 32
PAYLOAD_SECRET=change-me-to-a-long-random-secret-min-32-chars
POSTGRES_USER=ablaut
POSTGRES_PASSWORD=change-me-db-password
POSTGRES_DB=ablaut
DATABASE_URI=postgres://ablaut:change-me-db-password@db:5432/ablaut

# --- Database schema (production Docker) ---
# Local dev on host: PAYLOAD_DB_PUSH=true is OK.
# Portainer / production: always false — migrations run on startup instead.
PAYLOAD_DB_PUSH=false
PAYLOAD_RUN_MIGRATIONS=true
PAYLOAD_WAIT_FOR_DB=true

# --- App URLs (no trailing slash) ---
# Portainer example (LAN):
#   NEXT_PUBLIC_APP_URL=http://192.168.1.50:3000
#   PUBLIC_BASE_URL=http://192.168.1.50:3000
# Production example:
#   NEXT_PUBLIC_APP_URL=https://ablaut.example.com
#   PUBLIC_BASE_URL=https://ablaut.example.com
NEXT_PUBLIC_APP_URL=http://localhost:3000
PUBLIC_BASE_URL=http://localhost:3000

# --- LiveKit (browser must reach LIVEKIT_URL or LIVEKIT_PUBLIC_URL) ---
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=change-me-livekit-secret
# Local: ws://localhost:7880  |  Production: wss://livekit.example.com
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_USE_EXTERNAL_IP=false
# Optional override if LIVEKIT_URL is internal but browsers use a public WSS URL
LIVEKIT_PUBLIC_URL=

# --- LL-HLS compatibility fallback (enabled by default) ---
# Disable with FEATURE_HLS_EGRESS=false or LIVEKIT_EGRESS_ENABLED=false
# Requires redis + livekit-egress (included in docker-compose.yml by default)
FEATURE_HLS_EGRESS=true
LIVEKIT_EGRESS_ENABLED=true
HLS_PUBLIC_BASE_URL=http://localhost:3000/hls
HLS_SEGMENTS_DIR=/app/hls-segments
HLS_EGRESS_OUTPUT_DIR=/out

# Use the same host everywhere when testing on this machine (avoid mixing localhost + LAN IP)
# PUBLIC_BASE_URL=http://localhost:3000
#
# Phone WebRTC/mic on LAN HTTP is blocked by browsers — see docs/LOCAL_DOCKER.md
# Easiest Android dev workaround: chrome://flags → "Insecure origins treated as secure"
# Production / iPhone testing: use https:// URLs (ngrok, reverse proxy, or real domain)

# --- Feature modules (compile-time; disable with FEATURE_<ID>=false) ---
FEATURE_CORE=true
FEATURE_ORGANIZATIONS=true

# --- SMTP (optional) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@example.com

# --- First boot super admin (only when no users exist) ---
INITIAL_SUPER_ADMIN_EMAIL=
INITIAL_SUPER_ADMIN_PASSWORD=

# --- Local dev only (app on host, DB in Docker) ---
# DATABASE_URI=postgres://ablaut:change-me-db-password@localhost:5432/ablaut
# PAYLOAD_DATABASE=sqlite
# DATABASE_URI=file:./data/ablaut.db

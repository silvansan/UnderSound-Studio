# Core — required; use a long random string in production (openssl rand -hex 32)
PAYLOAD_SECRET=change-me-to-a-long-random-secret-min-32-chars
DATABASE_URI=postgres://undersound:change-me-db-password@db:5432/undersound

# PostgreSQL service credentials used by Docker Compose / Portainer
POSTGRES_USER=undersound
POSTGRES_PASSWORD=change-me-db-password
POSTGRES_DB=undersound

# Early deployment convenience: let Payload/Drizzle keep the schema in sync.
# Set PAYLOAD_DB_PUSH=false later when formal migrations are introduced.
PAYLOAD_DB_PUSH=true

# App URLs (no trailing slash)
NEXT_PUBLIC_APP_URL=http://localhost:3000
PUBLIC_BASE_URL=http://localhost:3000

# LiveKit service included in docker-compose.yml.
# Use a long random LIVEKIT_API_SECRET in production.
# Browser clients must reach this URL directly, so keep localhost for local testing
# and change it to your public HTTPS/WSS LiveKit origin in production.
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=change-me-livekit-secret
LIVEKIT_URL=ws://localhost:7880

# SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@example.com

# First boot super admin (created only when no users exist)
INITIAL_SUPER_ADMIN_EMAIL=
INITIAL_SUPER_ADMIN_PASSWORD=

# Optional: use SQLite for local dev instead of Postgres
# DATABASE_URI=file:./data/undersound.db
# PAYLOAD_DATABASE=sqlite

# Local host development note:
# If you run only the database in docker-compose.dev.yml and run the app with npm on your host,
# use DATABASE_URI=postgres://undersound:change-me-db-password@localhost:5432/undersound
